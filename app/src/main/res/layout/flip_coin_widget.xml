<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_coin_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FLIP A COIN"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#6750A4"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/widget_coin_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HEADS"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#1D1B20"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.05" />

        <ImageButton
            android:id="@+id/widget_coin_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_heart"
            android:background="@drawable/widget_button_primary"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF"
            android:elevation="4dp"
            android:contentDescription="Flip" />
    </LinearLayout>

</RelativeLayout>
