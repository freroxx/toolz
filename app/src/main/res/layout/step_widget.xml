<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_step_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_directions"
            android:tint="#6750A4"
            android:contentDescription="Steps" />

        <TextView
            android:id="@+id/widget_step_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEPS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#6750A4"
            android:layout_marginStart="8dp"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_step_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#1D1B20" />

            <TextView
                android:id="@+id/widget_step_goal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GOAL: 10,000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#49454F"
                android:alpha="0.7" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_step_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminate="false"
            android:progressDrawable="@drawable/circular_progress" />
    </LinearLayout>

</LinearLayout>
