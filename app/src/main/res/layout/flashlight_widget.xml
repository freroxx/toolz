<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:id="@+id/widget_flashlight_toggle_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageButton
            android:id="@+id/widget_flashlight_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:background="@drawable/circle_background"
            android:backgroundTint="#FFD54F"
            android:tint="#000000"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:contentDescription="Toggle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Power"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1C1B1F"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageButton
            android:id="@+id/widget_flashlight_strobe"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_menu_compass"
            android:background="@drawable/circle_background"
            android:backgroundTint="#E1E2EC"
            android:tint="#1C1B1F"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:contentDescription="Strobe" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Strobe"
            android:textSize="12sp"
            android:textColor="#49454F"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageButton
            android:id="@+id/widget_flashlight_sos"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_menu_help"
            android:background="@drawable/circle_background"
            android:backgroundTint="#F9DEDC"
            android:tint="#410E0B"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:contentDescription="SOS" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOS"
            android:textSize="12sp"
            android:textColor="#49454F"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</LinearLayout>
