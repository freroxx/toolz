<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:id="@+id/widget_compass_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_compass_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="#6750A4"
            android:contentDescription="Compass" />

        <TextView
            android:id="@+id/widget_compass_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EXPLORE"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#6750A4"
            android:layout_marginStart="6dp"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_compass_header"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/widget_compass_dial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_compass"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="#49454F"
            android:alpha="0.2"
            android:contentDescription="Dial" />

        <ImageView
            android:id="@+id/widget_compass_needle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_directions"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="#B3261E"
            android:contentDescription="Needle" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="center"
            android:background="@drawable/widget_button_tonal" />
    </FrameLayout>

    <View
        android:layout_width="4dp"
        android:layout_height="12dp"
        android:layout_below="@id/widget_compass_header"
        android:layout_centerHorizontal="true"
        android:background="#6750A4" />

</RelativeLayout>
