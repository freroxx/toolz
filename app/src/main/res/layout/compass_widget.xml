<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <ImageView
        android:id="@+id/widget_compass_icon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="8dp"
        android:src="@android:drawable/ic_menu_compass"
        android:tint="#6750A4"
        android:contentDescription="Compass" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_compass_icon"
        android:layout_centerVertical="true"
        android:layout_marginStart="24dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_compass_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPASS"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#6750A4"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/widget_compass_direction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="North-East"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="#1D1B20"
            android:layout_marginTop="2dp" />
            
        <TextView
            android:id="@+id/widget_compass_degrees"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="45°"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#49454F"
            android:alpha="0.7" />
    </LinearLayout>

            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_compass"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="#49454F"
            android:alpha="0.2"
            android:contentDescription="Dial" />

        <ImageView
            android:id="@+id/widget_compass_needle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_directions"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="#B3261E"
            android:contentDescription="Needle" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="center"
            android:background="@drawable/widget_button_tonal" />
    </FrameLayout>

    <View
        android:layout_width="4dp"
        android:layout_height="12dp"
        android:layout_below="@id/widget_compass_header"
        android:layout_centerHorizontal="true"
        android:background="#6750A4" />

</RelativeLayout>
