<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp"
    android:background="@drawable/widget_background">

    <ImageView
        android:id="@+id/widget_music_album_art"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_music_note"
        android:scaleType="centerCrop"
        android:background="@drawable/widget_item_background"
        android:contentDescription="Album Art" />

    <LinearLayout
        android:id="@+id/widget_text_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_music_album_art"
        android:layout_toStartOf="@id/widget_controls_container"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="4dp">

        <TextView
            android:id="@+id/widget_music_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOT PLAYING"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#1D1B20"
            android:singleLine="true"
            android:ellipsize="marquee" />

        <TextView
            android:id="@+id/widget_music_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toolz Media"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#49454F"
            android:singleLine="true"
            android:ellipsize="end"
            android:alpha="0.8" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_controls_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="4dp"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/widget_music_prev"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:tint="#49454F"
            android:contentDescription="Previous" />

        <ImageButton
            android:id="@+id/widget_music_play_pause"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@android:drawable/ic_media_play"
            android:background="@drawable/widget_button_primary"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF"
            android:layout_marginHorizontal="2dp"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/widget_music_next"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@android:drawable/ic_media_next"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:tint="#49454F"
            android:contentDescription="Next" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/widget_music_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="2dp"
        android:max="100"
        android:progress="0"
        android:progressBackgroundTint="#E6E0E9"
        android:progressTint="#6750A4" />

</RelativeLayout>
