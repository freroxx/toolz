<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:clickable="true"
    android:focusable="true"
    android:keepScreenOn="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            
            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@android:drawable/btn_default"
                android:backgroundTint="#1AFFFFFF"
                android:layout_gravity="center" />
                
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_lock_power_off"
                android:tint="#FF3B30"
                android:layout_gravity="center" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_lock_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="FOCUS FLOW ACTIVE"
            android:textColor="#FF3B30"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.3" />

        <TextView
            android:id="@+id/tv_lock_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Daily Limit Reached"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Toolz has locked this application to preserve your focus. Take a meaningful break."
            android:textAlignment="center"
            android:textColor="#8E8E93"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/btn_exit"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="64dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:text="CLOSE AND TAKE A BREAK"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

    </LinearLayout>

</RelativeLayout>
